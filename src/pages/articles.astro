---
import Layout from "@/layouts/layout.astro";
import Pattern from "@/components/ui/pattern.astro";

import Navbar from "@/components/sections/navbar/index.astro";
import ArticlesSection from "@/components/sections/articles.astro";
---

<Layout title="Articles - Yash">
  <Navbar />
  <main
    aria-label="Main content"
    class="mx-auto min-h-[calc(100vh-120px)] max-w-3xl"
  >
    <Pattern className="h-14" />
    <ArticlesSection />
    <Pattern />
  </main>
</Layout>
