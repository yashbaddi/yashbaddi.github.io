---
import { getCollection, render, type CollectionEntry } from "astro:content";
import Layout from "@/layouts/layout.astro";
import Navbar from "@/components/sections/navbar/index.astro";
import Pattern from "@/components/ui/pattern.astro";
import Box from "@/components/box/index.astro";
import BoxHeader from "@/components/box/header.astro";
import BoxTitle from "@/components/box/title.astro";
import BoxContent from "@/components/box/content.astro";

export async function getStaticPaths() {
  const articles = await getCollection("articles");
  return articles.map((entry) => ({
    params: { slug: entry.id.replace(/\.[^/.]+$/, "") },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<"articles">;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<Layout title={`${entry.data.title} - Yash`}>
  <Navbar />
  <main aria-label="Main content" class="min-h-[calc(100vh-120px)]">
    <Pattern className="h-14" />
    <Box>
      <BoxHeader>
        <div class="flex flex-col gap-1">
          <time class="text-xs text-neutral-500 dark:text-neutral-400">
            {
              entry.data.pubDate.toLocaleDateString("en-US", {
                year: "numeric",
                month: "long",
                day: "numeric",
              })
            }
          </time>
          <BoxTitle>{entry.data.title}</BoxTitle>
        </div>
      </BoxHeader>
      <BoxContent className="prose prose-neutral dark:prose-invert max-w-none">
        <Content />
      </BoxContent>
    </Box>
    <Pattern />
  </main>
</Layout>

<style is:global>
  @reference "tailwindcss";

  /* Basic styling for the article content */
  .prose h2 {
    @apply text-xl font-bold mt-8 mb-4;
  }
  .prose h3 {
    @apply text-lg font-bold mt-6 mb-3;
  }
  .prose p {
    @apply mb-4 leading-7 text-neutral-600 dark:text-neutral-300;
  }
  .prose ul {
    @apply list-disc list-inside mb-4 ml-4;
  }
  .prose pre {
    @apply p-4 rounded-lg bg-neutral-100 dark:bg-neutral-900 overflow-x-auto mb-4 border border-neutral-200 dark:border-neutral-800;
  }
  .prose code {
    @apply text-sm font-mono;
  }
  .prose img {
    @apply rounded-lg border border-neutral-200 dark:border-neutral-800 my-8 block max-w-full h-auto mx-auto;
  }
  .prose video {
    @apply rounded-lg my-8 w-full border border-neutral-200 dark:border-neutral-800 shadow-sm;
  }
</style>
